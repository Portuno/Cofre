# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cofre_vault

# ElevenLabs Configuration (audio transcription)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
# Embedding model — options: text-embedding-004 (default), embedding-001
EMBEDDING_MODEL=text-embedding-004
# LLM model — options: gemini-1.5-flash (default), gemini-1.5-pro, gemini-2.0-flash, gemini-2.5-pro
LLM_MODEL=gemini-1.5-flash
# Similarity threshold for graph edges (0.0–1.0, default 0.8)
SIMILARITY_THRESHOLD=0.8

# API Server
API_ADDR=0.0.0.0:3000

# Optional: Logging
RUST_LOG=info
